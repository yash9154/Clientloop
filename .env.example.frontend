# ================================
# ClientLoop Frontend Configuration
# ================================
# Copy this file to .env and fill in your values

# ================================
# Application
# ================================
VITE_APP_NAME=ClientLoop
VITE_APP_URL=http://localhost:3000

# ================================
# Backend API
# ================================
VITE_API_URL=http://localhost:5000/api

# ================================
# Google OAuth (REQUIRED - for "Login with Google")
# ================================
# Get from: https://console.cloud.google.com
# Must match backend GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ================================
# Stripe (OPTIONAL - for paid subscriptions)
# ================================
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx

# ================================
# Feature Flags
# ================================
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_BILLING=false

# ================================
# Sentry Error Tracking (OPTIONAL)
# ================================
# VITE_SENTRY_DSN=https://xxxxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxxx
