# ================================
# ClientLoop Backend Configuration
# ================================
# Copy this file to .env and fill in your values
# NEVER commit .env file with real credentials!

# ================================
# Server Configuration
# ================================
PORT=5000
NODE_ENV=development

# ================================
# MongoDB Atlas (FREE - 512MB)
# ================================
# IMPORTANT: Change your database password IMMEDIATELY!
# 1. Go to https://mongodb.com/atlas → Sign up free
# 2. Create a FREE M0 cluster
# 3. Database Access → Add user with password
# 4. Network Access → Add 0.0.0.0/0 (allow all IPs)
# 5. Connect → Drivers → Copy connection string
# 6. Replace <username> and <password> below
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/clientloop?retryWrites=true&w=majority

# ================================
# JWT Authentication (REQUIRED)
# ================================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d

# ================================
# Cloudinary File Storage (REQUIRED - FREE 25GB)
# ================================
# 1. Go to https://cloudinary.com → Sign up free
# 2. Dashboard → Copy these 3 values
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ================================
# Email Service (REQUIRED - Send client credentials & password reset)
# ================================
# Choose ONE email service:

# Option 1: Mailgun (RECOMMENDED - cheapest for volume)
# Sign up: https://mailgun.com (FREE for first 100/month)
EMAIL_SERVICE=mailgun
MAILGUN_API_KEY=key-xxxxxxxxxxxxx
MAILGUN_DOMAIN=mail.yourdomain.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# Option 2: Resend (easier for devs)
# Sign up: https://resend.com (FREE 100/month)
# EMAIL_SERVICE=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Option 3: SendGrid
# Sign up: https://sendgrid.com (FREE 100/month)
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Option 4: Gmail SMTP (NOT for production)
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com

# ================================
# Frontend URL (for CORS)
# ================================
CLIENT_URL=http://localhost:3000

# ================================
# Google OAuth (RECOMMENDED - for "Login with Google")
# ================================
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable OAuth 2.0
# 3. Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized URIs:
#    - JavaScript origins: http://localhost:3000
#    - Redirect URIs: http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ================================
# Stripe (OPTIONAL - for paid subscriptions)
# ================================
# Sign up: https://stripe.com
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ================================
# Security & Logging
# ================================
# Helmet.js security headers
HELMET_ENABLED=true

# Rate limiting (prevent brute force)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging (optional)
LOG_LEVEL=debug
LOG_FILE=logs/server.log

# ================================
# Optional: Error Tracking
# ================================
# Sign up: https://sentry.io (FREE tier)
SENTRY_DSN=
